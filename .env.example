# Railway provides this automatically when you add PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/kboos

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-char-random-string-here

# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=your-exactly-32-char-key-here!!

PORT=4000
