generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("agency")
  active    Boolean  @default(true)
  country   String   @default("MY")
  currency  String   @default("MYR")
  timezone  String   @default("Asia/Kuala_Lumpur")
  mobilePrefix String @default("+60")
  languages String[] @default(["EN","MS"])
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  tenantId      String    @default("default")
  email         String    @unique
  password      String
  name          String
  role          String    @default("operator")
  bizId         String?
  inviteToken   String?   @unique
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId])
}

model Business {
  id        String     @id
  tenantId  String     @default("default")
  name      String
  industry  String
  color     String     @default("blue")
  campaigns Int        @default(0)
  leads     Int        @default(0)
  hot       Int        @default(0)
  spend     String     @default("RM 0")
  brief            String     @default("none")
  contact          String     @default("")
  phone            String     @default("")
  email            String     @default("")
  website          String     @default("")
  commissionType   String     @default("percent")
  commissionValue  String     @default("")
  avgDealValue     Int        @default(0)
  briefContent     Json?
  status           String?
  createdAt        DateTime   @default(now())
  Campaign  Campaign[]

  @@index([tenantId])
}

model Campaign {
  id        Int      @id @default(autoincrement())
  tenantId  String   @default("default")
  bizId     String
  biz       Business @relation(fields: [bizId], references: [id])
  bizName   String
  name      String
  status    String   @default("active")
  color     String   @default("blue")
  leads     Int      @default(0)
  total     Int      @default(600)
  hot       Int      @default(0)
  spend     String   @default("RM 0")
  open      String   @default("0%")
  wa        String   @default("-")
  tier      String   @default("Starter")
  channels  String[] @default([])
  sequence  Json?
  config    Json?
  driveSync    Boolean   @default(false)
  startedAt    DateTime?
  dailyLimit   Int       @default(200)
  driveSheetId String?
  driveSheetUrl String?
  dailyLimitEmail  Int       @default(200)
  dailyLimitWa     Int       @default(200)
  dailyLimitVoice  Int       @default(20)
  createdAt DateTime @default(now())

  // V2 Revenue Engine fields
  offer              String  @default("")
  goal               String  @default("")
  targetAudience     String  @default("")
  personalizationLevel Int   @default(2)
  leadSource         String  @default("gmaps")
  channelStrategy    String?

  @@index([tenantId])
}

model Lead {
  id         Int      @id @default(autoincrement())
  tenantId   String   @default("default")
  campaignId Int?
  bizId      String?
  name       String
  company    String
  title      String   @default("")
  phone      String   @default("")
  email      String   @default("")
  website    String   @default("")
  address    String   @default("")
  score      Int      @default(0)
  status     String   @default("personalizing")
  lang       String   @default("EN")
  channels   String[]
  last             String    @default("now")
  clientStatus     String    @default("")
  lastContactedAt  DateTime?
  nextContactAt    DateTime?
  enriched         Boolean   @default(false)
  enrichedAt       DateTime?
  enrichmentNote   String?
  note             String    @default("")
  aiPriorityScore  Int?
  aiPriorityNote   String?
  aiPrioritizedAt  DateTime?
  aiNextAction     String?
  tier              String?
  validationScore   Int?
  personalized      Boolean   @default(false)
  personalizedAt    DateTime?
  meetingBooked     Boolean   @default(false)
  dealValue         Float?
  dealClosedAt      DateTime?
  createdAt        DateTime  @default(now())

  // V2 Revenue Engine fields
  rawQualityScore    Int?
  aiScore            Int?
  aiScoreReason      String?
  enrichmentConfidence Float?
  waEligible         Boolean  @default(false)
  emailEligible      Boolean  @default(false)
  voiceEligible      Boolean  @default(false)
  eligibilityChecked Boolean  @default(false)
  openingLine        String?
  category           String   @default("")
  rating             Float?
  reviewCount        Int?

  @@index([tenantId])
}

model Reply {
  id        Int      @id @default(autoincrement())
  tenantId  String   @default("default")
  leadId    Int?
  bizId     String?
  name      String
  company   String
  channel   String
  msg       String
  status    String   @default("unread")
  unsub     Boolean  @default(false)
  hot       Boolean  @default(false)
  thread      Json    @default("[]")
  aiDraft     String?
  aiStage     String  @default("cold")
  aiEscalate  Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Activity {
  id        Int      @id @default(autoincrement())
  tenantId  String   @default("default")
  color     String
  msg       String
  tag       String
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model AppSettings {
  id              String  @id @default("global")
  tenantId        String  @default("default")
  apiKeysEnc      Json    @default("{}")
  driveConnected  Boolean @default(false)
  billingSchedule String  @default("weekly")
  waTemplates      Json    @default("[]")
  domains          Json    @default("[]")
  team             Json    @default("[]")
  promptTemplates  Json    @default("[]")
  voiceTemplates   Json    @default("[]")
  notifications    Json?
  branding         Json?
  driveServiceAccountKey Json?
  monthlyBudget   Float   @default(1000)
  usdRmRate       Float   @default(4.70)
  replyPersonas  Json @default("[]")
  replyGoals     Json @default("[]")
  autoReplyConfig Json?

  @@index([tenantId])
}

model ApiUsageLog {
  id        Int      @id @default(autoincrement())
  tenantId  String   @default("default")
  service   String
  action    String
  units     Float    @default(0)
  costUsd   Float    @default(0)
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([service, createdAt])
  @@index([tenantId])
}

model CampaignAction {
  id         Int      @id @default(autoincrement())
  leadId     Int
  campaignId Int
  type       String
  stepDay    Int
  status     String   @default("sent")
  sentAt     DateTime
  openedAt   DateTime?
  errorMsg   String?
  jobId       String?
  retryCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([campaignId, stepDay, type])
  @@index([leadId])
}

model Wallet {
  id        String   @id @default("global")
  tenantId  String   @default("default")
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  tenantId    String   @default("default")
  type        String
  amountSen   Int
  billplzId   String?  @unique
  note        String   @default("")
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model BusinessSequence {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  bizId       String   @unique
  brief       Json     @default("{}")
  persona     Json     @default("{}")
  touchpoints Json     @default("[]")
  objections  Json     @default("[]")
  status      String   @default("draft")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model OnboardToken {
  id        String    @id @default(cuid())
  tenantId  String    @default("default")
  bizId     String
  bizName   String    @default("")
  token     String    @unique @default(cuid())
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model AiInsightCache {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    String
  insightType String
  result      Json
  inputHash   String
  computedAt  DateTime @default(now())
  expiresAt   DateTime

  @@unique([entityType, entityId, insightType])
  @@index([expiresAt])
}

model DemoProspect {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  name          String
  company       String
  industry      String   @default("")
  phone         String   @unique
  email         String
  lang          String   @default("EN")
  waMsg         String   @default("")
  emailSubject  String   @default("")
  emailBody     String   @default("")
  voiceScript   String   @default("")
  convoHistory  Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CampaignPipeline {
  id                  Int       @id @default(autoincrement())
  tenantId            String    @default("default")
  campaignId          Int       @unique
  stage               String    @default("draft")
  scrapeTotal         Int?
  scrapeComplete      Int?
  enrichTotal         Int?
  enrichComplete      Int?
  personalizeTotal    Int?
  personalizeComplete Int?
  eligibleEmail       Int?
  eligibleWa          Int?
  eligibleVoice       Int?
  ineligibleCount     Int?
  tierA               Int?
  tierB               Int?
  tierC               Int?
  approvedTiers       String[]  @default([])
  scrapedAt           DateTime?
  validatedAt         DateTime?
  enrichedAt          DateTime?
  assetsReadyAt       DateTime?
  personalizedAt      DateTime?
  launchedAt          DateTime?
  lastError           String?
  updatedAt           DateTime  @updatedAt

  // V2 Revenue Engine fields
  qualifyTotal        Int?
  qualifyComplete     Int?
  aiScoreTotal        Int?
  aiScoreComplete     Int?
  channelConfig       Json?
  deliverabilityScore Int?
  deliverabilityDetail Json?
  channelsConfiguredAt DateTime?
  aiScoredAt          DateTime?
  qualifiedAt         DateTime?
}

model CampaignOptimization {
  id           Int      @id @default(autoincrement())
  tenantId     String   @default("default")
  campaignId   Int
  analyzedAt   DateTime @default(now())
  metrics      Json     @default("{}")
  suggestions  Json     @default("[]")
  applied      Boolean  @default(false)

  @@index([campaignId])
}

model CampaignAsset {
  id          Int      @id @default(autoincrement())
  tenantId    String   @default("default")
  campaignId  Int
  assetType   String
  channel     String
  label       String
  subject     String?
  body        String
  notes       String?
  editedBody  String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
}

model LeadScore {
  id            Int      @id @default(autoincrement())
  leadId        Int      @unique
  tier          String
  qualityScore  Int
  signals       String[]
  hasWebsite    Boolean  @default(false)
  hasPhone      Boolean  @default(false)
  hasEmail      Boolean  @default(false)
  categoryMatch Boolean  @default(false)
  ratingOk      Boolean  @default(false)
  scoredAt      DateTime @default(now())
}

model LeadPersonalization {
  id            Int      @id @default(autoincrement())
  leadId        Int      @unique
  campaignId    Int
  openingLine   String
  variables     Json     @default("{}")
  generatedAt   DateTime @default(now())

  @@index([campaignId])
}

model LeadEligibility {
  id              Int      @id @default(autoincrement())
  leadId          Int
  campaignId      Int
  emailEligible   Boolean  @default(false)
  waEligible      Boolean  @default(false)
  voiceEligible   Boolean  @default(false)
  emailReason     String?
  waReason        String?
  voiceReason     String?
  checkedAt       DateTime @default(now())

  @@unique([leadId, campaignId])
}

model MeetingLog {
  id            Int      @id @default(autoincrement())
  tenantId      String   @default("default")
  leadId        Int
  campaignId    Int
  bizId         String
  meetingDate   DateTime?
  meetingType   String    @default("discovery")
  outcome       String    @default("booked")
  notes         String    @default("")
  revenue       Float?
  closedAt      DateTime?
  remindersSent Json      @default("[]")
  leadName      String    @default("")
  leadPhone     String    @default("")
  leadEmail     String    @default("")
  bizName       String    @default("")
  createdAt     DateTime  @default(now())

  @@index([campaignId])
  @@index([bizId])
  @@index([meetingDate])
  @@index([tenantId])
}
